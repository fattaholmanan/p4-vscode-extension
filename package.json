{
	"name": "p4-vscode-extension",
	"displayName": "P4 Language Extension",
	"description": "A language server/client for P4_16",
	"author": "Ali Fattaholmanan",
	"license": "Apache-2.0",
	"version": "0.2.0",
	"icon": "icons/icon.png",
	"repository": {
		"type": "git",
		"url": "https://github.com/fattaholmanan/p4-vscode-extension"
	},
	"publisher": "fattaholmanan",
	"categories": [
		"Programming Languages"
	],
	"keywords": [
		"p4",
		"p4_16",
		"networking",
		"language-server"
	],
	"engines": {
		"vscode": "^1.90.0"
	},
	"activationEvents": [
		"onLanguage:p4"
	],
	"main": "./client/out/extension.js",
	"contributes": {
		"configuration": {
			"type": "object",
			"title": "P4 Language Extension",
			"properties": {
				"p4.maxNumberOfProblems": {
					"scope": "resource",
					"type": "number",
					"default": 100,
					"description": "Controls the maximum number of problems reported per P4 file."
				},
				"p4.includePaths": {
					"scope": "resource",
					"type": "array",
					"items": {
						"type": "string"
					},
					"default": [],
					"description": "Additional directories searched when resolving #include directives. The bundled p4include/ directory (core.p4, v1model.p4, …) and the current file's directory are always searched."
				},
				"p4.trace.server": {
					"scope": "window",
					"type": "string",
					"enum": [
						"off",
						"messages",
						"verbose"
					],
					"default": "off",
					"description": "Traces the communication between VS Code and the P4 language server."
				}
			}
		},
		"languages": [
			{
				"id": "p4",
				"aliases": [
					"P4",
					"p4"
				],
				"extensions": [
					".p4",
					".p4p"
				],
				"configuration": "./client/p4.configuration.json"
			}
		],
		"grammars": [
			{
				"language": "p4",
				"scopeName": "source.p4",
				"path": "./client/syntaxes/p4.tmLanguage"
			}
		],
		"snippets": [
			{
				"language": "p4",
				"path": "./snippets/table.code-snippets"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run check-types && node esbuild.js --production",
		"build": "node esbuild.js",
		"watch": "node esbuild.js --watch",
		"check-types": "tsc -p client/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit",
		"lint": "eslint client/src server/src",
		"test:unit": "mocha",
		"test:integration": "vscode-test",
		"test": "npm run test:unit && npm run test:integration",
		"package": "vsce package",
		"gen:parser": "node scripts/gen-parser.mjs"
	},
	"workspaces": [
		"client",
		"server"
	],
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/mocha": "^10.0.10",
		"@types/node": "^26.0.1",
		"@types/vscode": "1.90",
		"@vscode/test-cli": "^0.0.15",
		"@vscode/test-electron": "^3.0.0",
		"@vscode/vsce": "^3.9.2",
		"antlr-ng": "^1.0.10",
		"esbuild": "^0.28.1",
		"eslint": "^10.6.0",
		"mocha": "^11.7.6",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.0"
	}
}
